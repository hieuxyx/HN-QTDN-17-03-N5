<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tro_ly_form" model="ir.ui.view">
        <field name="name">tro_ly_tai_san.form</field>
        <field name="model">tro_ly_tai_san</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="cau_hoi" placeholder="VD: Tài sản nào sắp khấu hao hết? Tổng nguyên giá là bao nhiêu?"/>
                    <field name="tra_loi"/>
                </group>
                <footer>
                    <button name="action_hoi" type="object" string="Hỏi AI" class="btn-primary"/>
                    <button string="Đóng" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_tro_ly" model="ir.actions.act_window">
        <field name="name">Trợ lý AI hỏi - đáp</field>
        <field name="res_model">tro_ly_tai_san</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
