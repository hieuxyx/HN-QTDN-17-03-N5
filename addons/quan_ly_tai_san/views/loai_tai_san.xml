<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loai_tai_san_tree" model="ir.ui.view">
        <field name="name">loai_tai_san.tree</field>
        <field name="model">loai_tai_san</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ma"/>
                <field name="ten"/>
                <field name="so_ky_mac_dinh"/>
            </tree>
        </field>
    </record>
    <record id="view_loai_tai_san_form" model="ir.ui.view">
        <field name="name">loai_tai_san.form</field>
        <field name="model">loai_tai_san</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="ma"/>
                        <field name="ten"/>
                        <field name="so_ky_mac_dinh"/>
                        <field name="tk_tai_san_id"/>
                        <field name="tk_hao_mon_id"/>
                        <field name="tk_chi_phi_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_loai_tai_san" model="ir.actions.act_window">
        <field name="name">Loại tài sản</field>
        <field name="res_model">loai_tai_san</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
