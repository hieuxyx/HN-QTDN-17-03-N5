<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_asset" model="ir.module.category">
        <field name="name">Quản lý tài sản</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_asset_user" model="res.groups">
        <field name="name">Người dùng (xem tài sản được giao)</field>
        <field name="category_id" ref="module_category_asset"/>
    </record>

    <record id="group_asset_manager" model="res.groups">
        <field name="name">Quản lý tài sản (toàn quyền)</field>
        <field name="category_id" ref="module_category_asset"/>
        <field name="implied_ids" eval="[(4, ref('group_asset_user'))]"/>
    </record>

    <!-- Người dùng thường chỉ thấy tài sản mình quản lý hoặc tự tạo -->
    <record id="asset_rule_user_own" model="ir.rule">
        <field name="name">Người dùng: chỉ xem tài sản được giao</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_asset_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Quản lý thấy tất cả -->
    <record id="asset_rule_manager_all" model="ir.rule">
        <field name="name">Quản lý: xem tất cả tài sản</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_asset_manager'))]"/>
    </record>
</odoo>
