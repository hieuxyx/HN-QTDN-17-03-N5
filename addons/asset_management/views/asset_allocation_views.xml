<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_allocation_tree" model="ir.ui.view">
        <field name="name">asset.allocation.tree</field>
        <field name="model">asset.allocation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="date"/>
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="return_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'allocated'"
                       decoration-muted="state == 'returned'"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_allocation_form" model="ir.ui.view">
        <field name="name">asset.allocation.form</field>
        <field name="model">asset.allocation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_allocate" string="Cấp phát" type="object"
                            class="oe_highlight" states="draft"/>
                    <button name="action_return" string="Thu hồi" type="object" states="allocated"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="employee_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="return_date"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Ghi chú bàn giao..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_asset_allocation" model="ir.actions.act_window">
        <field name="name">Cấp phát / Bàn giao</field>
        <field name="res_model">asset.allocation</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
