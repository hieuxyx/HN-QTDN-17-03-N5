<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_asset_tree" model="ir.ui.view">
        <field name="name">asset.asset.tree</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="original_value" sum="Tổng nguyên giá"/>
                <field name="depreciated_value" sum="Đã khấu hao"/>
                <field name="value_residual" sum="Còn lại"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'open'"
                       decoration-warning="state == 'paused'"
                       decoration-muted="state in ('close','disposed')"/>
                <field name="currency_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_asset_form" model="ir.ui.view">
        <field name="name">asset.asset.form</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_ai_suggest" string="🤖 Gợi ý bằng AI" type="object"
                            states="draft"/>
                    <button name="action_confirm" string="Đưa vào sử dụng" type="object"
                            class="oe_highlight" states="draft"/>
                    <button name="compute_depreciation_board" string="Tính lại bảng khấu hao"
                            type="object" states="draft,open"/>
                    <button name="action_pause" string="Tạm dừng" type="object" states="open"/>
                    <button name="action_resume" string="Tiếp tục" type="object" states="paused"/>
                    <button name="action_dispose" string="Thanh lý" type="object"
                            states="open,paused,close"
                            confirm="Xác nhận thanh lý tài sản và ghi giảm khỏi sổ?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,open,close,disposed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_entries" type="object" class="oe_stat_button" icon="fa-book">
                            <field name="entry_count" widget="statinfo" string="Bút toán"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Tên tài sản..."/></h1>
                    </div>
                    <group>
                        <group string="Thông tin chung">
                            <field name="code"/>
                            <field name="category_id"/>
                            <field name="acquisition_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Giá trị">
                            <field name="original_value"/>
                            <field name="salvage_value"/>
                            <field name="depreciated_value"/>
                            <field name="value_residual"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Khấu hao" name="depreciation">
                            <group>
                                <group>
                                    <field name="method"/>
                                    <field name="method_number"/>
                                    <field name="method_period"/>
                                </group>
                                <group>
                                    <field name="degressive_factor"
                                           attrs="{'invisible': [('method','!=','degressive')]}"/>
                                    <field name="prorata"/>
                                    <field name="date_start"/>
                                </group>
                            </group>
                            <field name="depreciation_line_ids">
                                <tree editable="bottom" create="false">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="depreciation_date"/>
                                    <field name="amount"/>
                                    <field name="depreciated_value"/>
                                    <field name="remaining_value"/>
                                    <field name="move_posted"/>
                                    <field name="move_id"/>
                                    <field name="currency_id" invisible="1"/>
                                    <button name="action_create_move" type="object"
                                            string="Ghi sổ" icon="fa-check"
                                            attrs="{'invisible': [('move_posted','=',True)]}"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Nhân sự &amp; Sử dụng" name="hr">
                            <group>
                                <field name="employee_id"/>
                                <field name="department_id"/>
                            </group>
                        </page>
                        <page string="Kế toán" name="accounting">
                            <group>
                                <field name="account_asset_id"/>
                                <field name="account_depreciation_id"/>
                                <field name="account_expense_id"/>
                                <field name="journal_id"/>
                            </group>
                        </page>
                        <page string="Bút toán đã ghi" name="entries">
                            <field name="move_line_ids" readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="move_id"/>
                                    <field name="account_id"/>
                                    <field name="name"/>
                                    <field name="debit"/>
                                    <field name="credit"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_asset_asset_search" model="ir.ui.view">
        <field name="name">asset.asset.search</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="category_id"/>
                <filter name="open" string="Đang khấu hao" domain="[('state','=','open')]"/>
                <filter name="disposed" string="Đã thanh lý" domain="[('state','=','disposed')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_category" string="Nhóm tài sản" context="{'group_by':'category_id'}"/>
                    <filter name="group_department" string="Phòng ban" context="{'group_by':'department_id'}"/>
                    <filter name="group_state" string="Trạng thái" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_asset_asset" model="ir.actions.act_window">
        <field name="name">Tài sản cố định</field>
        <field name="res_model">asset.asset</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_asset_asset_search"/>
    </record>
</odoo>
