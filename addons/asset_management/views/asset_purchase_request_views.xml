<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_purchase_tree" model="ir.ui.view">
        <field name="name">asset.purchase.request.tree</field>
        <field name="model">asset.purchase.request</field>
        <field name="arch" type="xml">
            <tree decoration-danger="over_budget == True and state in ('draft','to_approve')">
                <field name="name"/>
                <field name="request_date"/>
                <field name="description"/>
                <field name="department_id"/>
                <field name="employee_id"/>
                <field name="total_cost" sum="Tổng dự kiến"/>
                <field name="over_budget" invisible="1"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'approved'"
                       decoration-muted="state == 'refused'"/>
                <field name="currency_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_purchase_form" model="ir.ui.view">
        <field name="name">asset.purchase.request.form</field>
        <field name="model">asset.purchase.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Trình duyệt" type="object"
                            class="oe_highlight" states="draft"/>
                    <button name="action_approve" string="Duyệt" type="object"
                            class="oe_highlight" states="to_approve"
                            groups="asset_management.group_asset_manager"/>
                    <button name="action_refuse" string="Từ chối" type="object" states="to_approve"
                            groups="asset_management.group_asset_manager"/>
                    <button name="action_purchase" string="Đã mua / Ghi tăng tài sản" type="object"
                            class="oe_highlight" states="approved"/>
                    <button name="action_reset" string="Về nháp" type="object"
                            states="refused,to_approve"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,to_approve,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_asset" type="object"
                                class="oe_stat_button" icon="fa-cube"
                                attrs="{'invisible': [('asset_id','=',False)]}">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Tài sản</span>
                            </div>
                        </button>
                    </div>
                    <field name="asset_id" invisible="1"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <div class="alert alert-warning" role="alert"
                         attrs="{'invisible': [('over_budget','=',False)]}">
                        Cảnh báo: đề xuất này vượt ngân sách còn lại của phòng ban.
                    </div>
                    <group>
                        <group string="Nội dung đề xuất">
                            <field name="description"/>
                            <field name="category_id"/>
                            <field name="quantity"/>
                            <field name="unit_cost"/>
                            <field name="total_cost"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Đơn vị &amp; Ngân sách">
                            <field name="employee_id"/>
                            <field name="department_id"/>
                            <field name="request_date"/>
                            <field name="budget_id"/>
                            <field name="account_payable_id"/>
                            <field name="over_budget" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_asset_purchase_search" model="ir.ui.view">
        <field name="name">asset.purchase.request.search</field>
        <field name="model">asset.purchase.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
                <field name="department_id"/>
                <field name="employee_id"/>
                <filter name="to_approve" string="Chờ duyệt" domain="[('state','=','to_approve')]"/>
                <filter name="committed" string="Đã duyệt/đã mua" domain="[('state','in',('approved','done'))]"/>
                <filter name="done" string="Đã mua" domain="[('state','=','done')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="g_dept" string="Phòng ban" context="{'group_by':'department_id'}"/>
                    <filter name="g_month" string="Tháng đề xuất" context="{'group_by':'request_date:month'}"/>
                    <filter name="g_state" string="Trạng thái" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_asset_purchase_request" model="ir.actions.act_window">
        <field name="name">Đề xuất mua sắm</field>
        <field name="res_model">asset.purchase.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_asset_purchase_search"/>
    </record>
</odoo>
