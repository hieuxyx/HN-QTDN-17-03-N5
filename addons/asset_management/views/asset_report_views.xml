<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_asset_purchase_pivot" model="ir.ui.view">
        <field name="name">asset.purchase.request.pivot</field>
        <field name="model">asset.purchase.request</field>
        <field name="arch" type="xml">
            <pivot string="Dòng tiền mua sắm">
                <field name="request_date" interval="month" type="row"/>
                <field name="department_id" type="col"/>
                <field name="total_cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_asset_purchase_graph" model="ir.ui.view">
        <field name="name">asset.purchase.request.graph</field>
        <field name="model">asset.purchase.request</field>
        <field name="arch" type="xml">
            <graph string="Dòng tiền mua sắm" type="bar">
                <field name="request_date" interval="month"/>
                <field name="total_cost" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_asset_cashflow_report" model="ir.actions.act_window">
        <field name="name">Dòng tiền &amp; Ngân sách mua sắm</field>
        <field name="res_model">asset.purchase.request</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="search_view_id" ref="view_asset_purchase_search"/>
        <field name="context">{'search_default_committed': 1, 'search_default_g_month': 1}</field>
    </record>
</odoo>
