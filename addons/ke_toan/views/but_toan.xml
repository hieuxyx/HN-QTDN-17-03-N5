<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_but_toan_tree" model="ir.ui.view">
        <field name="name">but_toan.tree</field>
        <field name="model">but_toan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="so_but_toan"/>
                <field name="ngay"/>
                <field name="dien_giai"/>
                <field name="nguoi_lap_id"/>
                <field name="tong_no"/>
                <field name="tong_co"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>
    <record id="view_but_toan_form" model="ir.ui.view">
        <field name="name">but_toan.form</field>
        <field name="model">but_toan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_ghi_so" type="object" string="Ghi sổ" class="btn-primary"
                            attrs="{'invisible':[('trang_thai','!=','nhap')]}"/>
                    <button name="action_ve_nhap" type="object" string="Về nháp"
                            attrs="{'invisible':[('trang_thai','!=','da_ghi_so')]}"/>
                    <field name="trang_thai" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="so_but_toan" readonly="1"/>
                        <field name="ngay"/>
                        <field name="nguoi_lap_id"/>
                        <field name="dien_giai"/>
                    </group>
                    <field name="dong_but_toan_ids">
                        <tree editable="bottom">
                            <field name="tai_khoan_id"/>
                            <field name="dien_giai"/>
                            <field name="ghi_no"/>
                            <field name="ghi_co"/>
                        </tree>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="tong_no"/>
                        <field name="tong_co"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_but_toan" model="ir.actions.act_window">
        <field name="name">Bút toán</field>
        <field name="res_model">but_toan</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Sổ cái: các dòng bút toán, gom nhóm theo tài khoản -->
    <record id="view_so_cai_tree" model="ir.ui.view">
        <field name="name">dong_but_toan.tree</field>
        <field name="model">dong_but_toan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ngay"/>
                <field name="tai_khoan_id"/>
                <field name="but_toan_id"/>
                <field name="dien_giai"/>
                <field name="ghi_no" sum="Tổng Nợ"/>
                <field name="ghi_co" sum="Tổng Có"/>
            </tree>
        </field>
    </record>
    <record id="action_so_cai" model="ir.actions.act_window">
        <field name="name">Sổ cái</field>
        <field name="res_model">dong_but_toan</field>
        <field name="view_mode">tree</field>
        <field name="context">{'group_by': 'tai_khoan_id'}</field>
    </record>
</odoo>
