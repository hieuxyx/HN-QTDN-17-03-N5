<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tai_khoan_tree" model="ir.ui.view">
        <field name="name">tai_khoan_ke_toan.tree</field>
        <field name="model">tai_khoan_ke_toan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="ma_tai_khoan"/>
                <field name="ten_tai_khoan"/>
                <field name="loai"/>
            </tree>
        </field>
    </record>
    <record id="view_tai_khoan_form" model="ir.ui.view">
        <field name="name">tai_khoan_ke_toan.form</field>
        <field name="model">tai_khoan_ke_toan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="ma_tai_khoan"/>
                        <field name="ten_tai_khoan"/>
                        <field name="loai"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_tai_khoan" model="ir.actions.act_window">
        <field name="name">Hệ thống tài khoản</field>
        <field name="res_model">tai_khoan_ke_toan</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
